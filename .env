# Smart Grid Digital Twin — Environment Variables
# To enable real LLM responses, add your OpenRouter API key below.
# Get one at: https://openrouter.ai/keys

VITE_OPENROUTER_API_KEY=

# ──────────────────────────────────────────────────────────
# Without a key, the app runs a realistic mock LLM advisor
# that simulates a 1.8s response delay and returns a
# pre-built fault analysis based on real grid state data.
# ──────────────────────────────────────────────────────────
